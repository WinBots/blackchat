# Backend .env (exemplo)

# App
ENVIRONMENT=local
DEBUG=true
DATABASE_URL=sqlite:///./data/app.db
JWT_SECRET_KEY=changeme
PUBLIC_BASE_URL=http://localhost:8061

# SMTP (Titan/HostGator)
# Titan costuma funcionar com smtp.titan.email (STARTTLS 587) ou o host SMTP do seu domínio.
SMTP_ENABLED=true
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USER=seu_email@seudominio.com.br
SMTP_PASSWORD=sua_senha_ou_app_password
SMTP_FROM_EMAIL=seu_email@seudominio.com.br
SMTP_FROM_NAME=WinChat
