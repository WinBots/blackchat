ENVIRONMENT=production
DEBUG=False
APP_NAME=ManyChatLike
APP_HOST=0.0.0.0
APP_PORT=8061
# SQL Server (produção)
# Exemplo:
# mssql+pyodbc://USER:PASSWORD@HOST:1433/DBNAME?driver=ODBC+Driver+17+for+SQL+Server
DATABASE_URL=mssql+pyodbc://USER:PASSWORD@HOST:1433/DBNAME?driver=ODBC+Driver+17+for+SQL+Server
ALLOW_SQLITE=false

# URLs
PUBLIC_BASE_URL=https://SEU-DOMINIO-DO-BACKEND
FRONTEND_URL=https://SEU-DOMINIO-DO-FRONTEND

# Stripe (modo LIVE em produção)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Plano Pro (preço fixo) — copie o price_... do modo LIVE
STRIPE_PRO_PRICE_ID_MONTHLY=
STRIPE_PRO_PRICE_ID_YEARLY=

JWT_SECRET_KEY=changeme_prod_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
